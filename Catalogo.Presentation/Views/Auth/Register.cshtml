
@{
    ViewData["Title"] = "Crear cuenta";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <h2 class="mb-4">Crear cuenta</h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form method="post">
            <div class="mb-3">
                <label class="form-label">Nombre de usuario</label>
                <input type="text" name="nombreUsuario" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Correo electrónico</label>
                <input type="email" name="email" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input type="password" name="password" class="form-control" minlength="6" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Confirmar contraseña</label>
                <input type="password" name="confirmarPassword" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-success w-100">Registrarse</button>
        </form>

        <div class="mt-3 text-center">
            <a asp-controller="Auth" asp-action="Login">¿Ya tienes cuenta? Inicia sesión</a>
        </div>
    </div>
</div>
