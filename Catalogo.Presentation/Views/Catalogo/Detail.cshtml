
@using CatalogoApp.Domain.Models
@model Item

@{
    ViewData["Title"] = Model.Nombre;
    var reviews   = ViewBag.Reviews  as List<Review> ?? new List<Review>();
    var avg       = (double)(ViewBag.AverageRating ?? 0.0);
    var loggedIn  = Context.Session.GetString("UsuarioNombre") != null;
}
<head>
    <link rel="stylesheet" href="~/css/detail.css" />   
</head>
<div class="container py-4" style="max-width:820px;">

    <a asp-controller="Catalogo" asp-action="Index" class="btn-back">← Volver al catálogo</a>

    
    <div class="detail-hero">
        <div class="cat-avatar">🐱</div>
        <div>
            <h1 class="cat-info-title">@Model.Nombre</h1>
            <div class="mb-2">
                <span class="cat-tag">@Model.Raza</span>
                <span class="cat-tag">@Model.Pelaje</span>
                <span class="cat-tag">@Model.Temperamento</span>
            </div>
            <p style="color:var(--muted);line-height:1.7;max-width:440px;">@Model.Descripcion</p>

            
            <div class="mt-2">
                @if (reviews.Count > 0)
                {
                    <span class="avg-stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="@(i <= Math.Round(avg) ? "star-on" : "star-off")">★</span>
                        }
                    </span>
                    <span style="font-size:.9rem;color:var(--muted);margin-left:.4rem;">
                        @avg / 5 &nbsp;·&nbsp; @reviews.Count review@(reviews.Count == 1 ? "" : "s")
                    </span>
                }
                else
                {
                    <span style="font-size:.9rem;color:var(--muted);">Sin reviews todavía</span>
                }
            </div>
        </div>
    </div>

    
    @if (loggedIn)
    {
        <div class="review-form-card">
            <h2 class="section-title">Deja tu review</h2>
            @if (TempData["ReviewError"] != null)
            {
                <div class="alert alert-danger py-2">@TempData["ReviewError"]</div>
            }
            <form method="post" asp-controller="Review" asp-action="Add">
                <input type="hidden" name="itemId" value="@Model.Id" />
                <div class="mb-3">
                    <label class="form-label" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);">Rating</label>
                    <div class="d-flex gap-3 align-items-center">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="rating"
                                       id="s@(i)" value="@i" required @(i == 5 ? "checked" : "") />
                                <label class="form-check-label" for="s@(i)" style="font-size:1.4rem;cursor:pointer;">★</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-size:.8rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);">Comentario</label>
                    <textarea name="comment" class="form-control" rows="3"
                              placeholder="¿Qué te parece este gato?" required></textarea>
                </div>
                <button type="submit" class="btn-post">Publicar review</button>
            </form>
        </div>
    }
    else
    {
        <div class="review-form-card" style="text-align:center;padding:2rem;">
            <span style="font-size:2rem;display:block;margin-bottom:.8rem;">🔐</span>
            <p style="color:var(--muted);margin-bottom:1rem;">Inicia sesión para dejar una review.</p>
            <a asp-controller="Auth" asp-action="Login" class="btn-post" style="text-decoration:none;border-radius:10px;display:inline-block;">Iniciar sesión</a>
        </div>
    }

    
    <h2 class="section-title">Reviews (@reviews.Count)</h2>

    @if (reviews.Count == 0)
    {
        <p style="color:var(--muted);text-align:center;padding:2rem 0;">🐾 Sé el primero en opinar sobre @Model.Nombre</p>
    }
    else
    {
        @foreach (var r in reviews)
        {
            <div class="review-card">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="review-user">@r.UserName</span>
                    <span>
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span style="color:@(i <= r.Rating ? "#f5a623" : "#ddd")">★</span>
                        }
                    </span>
                </div>
                <p class="review-text">@r.Comment</p>
                <span class="review-date">@r.CreatedAt.ToString("MMM dd, yyyy")</span>
            </div>
        }
    }

</div>
